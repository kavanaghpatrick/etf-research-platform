# Test Environment Variables
# Copy this file to .env.test and add your test API keys
# NEVER commit .env.test to version control

# Alpha Vantage API Key for testing
ALPHA_VANTAGE_API_KEY=your_test_alpha_vantage_key_here

# Tiingo API Key for testing
TIINGO_API_KEY=your_test_tiingo_key_here

# Finnhub API Key for testing
FINNHUB_API_KEY=your_test_finnhub_key_here

# Polygon API Key for testing (optional)
POLYGON_API_KEY=your_test_polygon_key_here

# FRED API Key for testing (optional)
FRED_API_KEY=your_test_fred_key_here