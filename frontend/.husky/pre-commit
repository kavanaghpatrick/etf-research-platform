#!/usr/bin/env sh

# Husky pre-commit hook for code quality checks
# This script runs various quality checks before allowing commits

. "$(dirname -- "$0")/_/husky.sh"

echo "🚀 Running pre-commit quality checks..."

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Function to print colored output
print_status() {
    echo -e "${BLUE}→${NC} $1"
}

print_success() {
    echo -e "${GREEN}✓${NC} $1"
}

print_warning() {
    echo -e "${YELLOW}⚠${NC} $1"
}

print_error() {
    echo -e "${RED}✗${NC} $1"
}

# Exit on any error
set -e

# 1. Check if staged files contain TypeScript/JavaScript files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx|js|jsx)$' || true)

if [ -z "$STAGED_FILES" ]; then
    print_warning "No TypeScript/JavaScript files staged for commit"
    exit 0
fi

echo "Staged files to check:"
echo "$STAGED_FILES" | sed 's/^/  - /'

# 2. Run TypeScript type checking
print_status "Running TypeScript type checking..."
if npm run type-check > /dev/null 2>&1; then
    print_success "TypeScript type checking passed"
else
    print_error "TypeScript type checking failed"
    echo "Run 'npm run type-check' to see the errors"
    exit 1
fi

# 3. Run ESLint on staged files
print_status "Running ESLint..."
if echo "$STAGED_FILES" | xargs npx eslint --fix; then
    print_success "ESLint checks passed"
else
    print_error "ESLint found issues"
    echo "Some issues may have been auto-fixed. Please review and stage the changes."
    exit 1
fi

# 4. Run Prettier on staged files
print_status "Running Prettier..."
if echo "$STAGED_FILES" | xargs npx prettier --write; then
    print_success "Prettier formatting completed"
else
    print_error "Prettier formatting failed"
    exit 1
fi

# 5. Add formatted files back to staging
if [ -n "$STAGED_FILES" ]; then
    echo "$STAGED_FILES" | xargs git add
    print_success "Re-staged formatted files"
fi

# 6. Run tests related to staged files
print_status "Running related tests..."
if npm run test -- --findRelatedTests $STAGED_FILES --passWithNoTests > /dev/null 2>&1; then
    print_success "Related tests passed"
else
    print_error "Some tests failed"
    echo "Run 'npm test' to see the test results"
    exit 1
fi

# 7. Check for large files
print_status "Checking for large files..."
LARGE_FILES=$(echo "$STAGED_FILES" | xargs ls -la | awk '$5 > 1048576 {print $9, "(" $5 " bytes)"}' || true)
if [ -n "$LARGE_FILES" ]; then
    print_warning "Large files detected (>1MB):"
    echo "$LARGE_FILES" | sed 's/^/  - /'
    echo "Consider if these files should be committed or added to .gitignore"
fi

# 8. Check for debugging statements
print_status "Checking for debugging statements..."
DEBUG_STATEMENTS=$(echo "$STAGED_FILES" | xargs grep -n -E "(console\.log|console\.debug|debugger)" || true)
if [ -n "$DEBUG_STATEMENTS" ]; then
    print_warning "Debugging statements found:"
    echo "$DEBUG_STATEMENTS" | sed 's/^/  - /'
    echo "Consider removing debugging statements before committing"
fi

# 9. Check for TODO/FIXME comments
print_status "Checking for TODO/FIXME comments..."
TODO_COMMENTS=$(echo "$STAGED_FILES" | xargs grep -n -E "(TODO|FIXME|HACK|XXX)" || true)
if [ -n "$TODO_COMMENTS" ]; then
    print_warning "TODO/FIXME comments found:"
    echo "$TODO_COMMENTS" | sed 's/^/  - /' | head -10
    if [ $(echo "$TODO_COMMENTS" | wc -l) -gt 10 ]; then
        echo "  ... and $(expr $(echo "$TODO_COMMENTS" | wc -l) - 10) more"
    fi
fi

# 10. Run complexity analysis on changed files
print_status "Running complexity analysis..."
if node scripts/analyze-complexity.js --files="$STAGED_FILES" --threshold-only > /dev/null 2>&1; then
    print_success "Complexity analysis passed"
else
    print_warning "Complexity thresholds exceeded"
    echo "Run 'node scripts/analyze-complexity.js' for detailed analysis"
fi

# 11. Check for security issues (basic check)
print_status "Running basic security checks..."
SECURITY_ISSUES=$(echo "$STAGED_FILES" | xargs grep -n -E "(password|secret|token|key|api_key)" -i || true)
if [ -n "$SECURITY_ISSUES" ]; then
    print_warning "Potential security issues found:"
    echo "$SECURITY_ISSUES" | sed 's/^/  - /' | head -5
    echo "Please review for hardcoded secrets or sensitive information"
fi

# 12. Validate package.json if it's being committed
if echo "$STAGED_FILES" | grep -q "package.json"; then
    print_status "Validating package.json..."
    if npm run validate-package > /dev/null 2>&1; then
        print_success "package.json validation passed"
    else
        print_warning "package.json validation issues found"
    fi
fi

# 13. Check for proper import statements
print_status "Checking import statements..."
RELATIVE_IMPORTS=$(echo "$STAGED_FILES" | xargs grep -n "import.*'\.\./\.\./\.\." || true)
if [ -n "$RELATIVE_IMPORTS" ]; then
    print_warning "Deep relative imports found (consider using absolute imports):"
    echo "$RELATIVE_IMPORTS" | sed 's/^/  - /' | head -5
fi

print_success "All pre-commit checks completed successfully!"
echo ""
echo "📊 Summary:"
echo "  - TypeScript type checking: ✓"
echo "  - ESLint: ✓"
echo "  - Prettier: ✓"
echo "  - Tests: ✓"
echo "  - Security check: ✓"
echo "  - Complexity analysis: ✓"
echo ""
echo "Ready to commit! 🚀"