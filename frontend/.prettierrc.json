{
  "semi": true,
  "singleQuote": true,
  "tabWidth": 2,
  "useTabs": false,
  "printWidth": 100,
  "trailingComma": "es5",
  "bracketSpacing": true,
  "bracketSameLine": false,
  "arrowParens": "avoid",
  "endOfLine": "lf",
  "quoteProps": "as-needed",
  "jsxSingleQuote": false,
  "embeddedLanguageFormatting": "auto",
  "overrides": [
    {
      "files": "*.{json,md}",
      "options": {
        "tabWidth": 2
      }
    },
    {
      "files": "*.{tsx,jsx}",
      "options": {
        "jsxBracketSameLine": false,
        "jsxSingleQuote": false
      }
    }
  ]
}