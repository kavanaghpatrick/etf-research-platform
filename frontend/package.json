{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "build:analyze": "ANALYZE=true npm run build",
    "build:baseline": "npm run build && npm run size:baseline",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "size:baseline": "du -sh .next && find .next -name '*.js' -exec du -ch {} + | tail-1",
    "perf:baseline": "npm run build:baseline && echo 'Baseline bundle analysis complete'",
    "test": "jest",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:coverage:report": "jest --coverage && open coverage/lcov-report/index.html",
    "test:unit": "jest --testPathPattern='.*\\.test\\.(ts|tsx)$'",
    "test:integration": "jest --testPathPattern='.*\\.integration\\.(ts|tsx)$'",
    "test:accessibility": "jest --testNamePattern=\"accessibility\"",
    "test:a11y": "npm run test:accessibility",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:accessibility": "playwright test src/tests/e2e/accessibility.spec.ts",
    "test:a11y:e2e": "npm run test:e2e:accessibility",
    "test:visual": "playwright test --config=playwright-visual.config.ts",
    "test:performance": "jest --testPathPattern='.*\\.perf\\.(ts|tsx)$'",
    "test:mutation": "stryker run",
    "test:mutation:report": "stryker run && open reports/mutation/html/index.html",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "test:report": "npm run test:coverage && npm run test:mutation && npm run test:e2e",
    "accessibility:audit": "axe --dir .next/static",
    "accessibility:report": "npm run test:accessibility && npm run test:e2e:accessibility",
    "a11y:audit": "npm run accessibility:audit",
    "a11y:report": "npm run accessibility:report",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "complexity": "node scripts/analyze-complexity.js",
    "generate:component": "node scripts/generate-component.js",
    "quality:check": "npm run type-check && npm run lint && npm run test:ci",
    "quality:fix": "npm run lint:fix && npm run format",
    "validate-package": "npm ls --depth=0",
    "prepare": "husky install || true",
    "precommit": "lint-staged",
    "perf:budget": "node scripts/performance-budget.js check",
    "perf:setup-ci": "node scripts/performance-budget.js setup-ci",
    "bundle:optimize": "node scripts/bundle-optimization-metrics.js optimized",
    "bundle:report": "node scripts/bundle-optimization-metrics.js report",
    "perf:load-test": "playwright test src/tests/performance/load-testing.test.ts",
    "perf:benchmark": "playwright test src/tests/performance/benchmark.test.ts",
    "perf:stress-test": "playwright test src/tests/performance/stress-testing.test.ts",
    "perf:validate": "playwright test src/tests/performance/optimization-validation.test.ts",
    "perf:all": "npm run perf:load-test && npm run perf:benchmark && npm run perf:stress-test && npm run perf:validate",
    "perf:report": "node scripts/generate-performance-report.js",
    "perf:monitor": "npm run build && npm run perf:all && npm run perf:report"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@nivo/axes": "^0.99.0",
    "@nivo/bar": "^0.99.0",
    "@nivo/core": "^0.99.0",
    "@nivo/line": "^0.99.0",
    "@nivo/tooltip": "^0.99.0",
    "axios": "^1.10.0",
    "jspdf": "^3.0.1",
    "jspdf-autotable": "^5.0.2",
    "next": "15.3.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-window": "^1.8.11"
  },
  "devDependencies": {
    "@axe-core/cli": "^4.10.2",
    "@axe-core/react": "^4.10.2",
    "@eslint/eslintrc": "^3",
    "@next/bundle-analyzer": "^15.3.5",
    "@playwright/test": "^1.54.1",
    "@stryker-mutator/core": "^8.0.0",
    "@stryker-mutator/jest-runner": "^8.0.0",
    "@stryker-mutator/typescript-checker": "^8.0.0",
    "@tailwindcss/postcss": "^4",
    "@tanstack/react-query": "^5.28.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest": "^29.5.12",
    "@types/jspdf": "^1.3.3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "axe-playwright": "^2.1.0",
    "eslint": "^9",
    "eslint-config-next": "15.3.5",
    "jest": "^29.7.0",
    "jest-axe": "^10.0.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-html-reporter": "^3.10.2",
    "jest-junit": "^16.0.0",
    "msw": "^2.2.0",
    "playwright-test": "^14.1.9",
    "stryker-cli": "^1.0.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
